# Optional fallback credentials only. Default runtime is gongfeng OAuth and normally needs no API key.
# DEEPSEEK_API_KEY=your_deepseek_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_compatible_key_here
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# XFYUN_API_KEY=your_xfyun_key_here

# ── 工蜂AI直连（腾讯内网机器推荐，无需配置，自动读取 OpenClaw OAuth token）──
# 无需手动填写。详见 docs/LLM_Config.md
# Token路径: %USERPROFILE%\.openclaw\agents\main\agent\auth-profiles.json (Windows)
#            ~/.openclaw/agents/main/agent/auth-profiles.json (macOS/Linux)

# ── OpenClaw Gateway（如果 Gateway 在本机运行）──
# OPENCLAW_API_URL=http://localhost:3000/v1
# OPENCLAW_MODEL=gongfeng/gpt-5-4
